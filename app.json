{
  "expo": {
    "name": "Teenage Sleep Diaries",
    "slug": "teenage-sleep-diaries",
    "version": "1.1.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#C8DFF5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.circadia.teenagesleepdiaries"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#C8DFF5"
      },
      "package": "com.circadia.teenagesleepdiaries"
    },
    "scheme": "teenage-sleep-diaries",
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-sharing"
    ],
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png",
      "template": "./web/index.html",
      "baseUrl": "/TeenageSleepDiaries"
    }
  }
}
